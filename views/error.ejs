<!DOCTYPE html>
<html>
<head>
<title>Error</title>
<style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f8f9fa;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .card {
      background: white;
      padding: 40px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      text-align: center;
      max-width: 400px;
    }
    h1 {
      color: #dc3545;
      margin-bottom: 20px;
    }
    p {
      color: #333;
      margin-bottom: 20px;
    }
    a {
      text-decoration: none;
      background: #007bff;
      color: white;
      padding: 10px 20px;
      border-radius: 5px;
    }
    a:hover {
      background: #0056b3;
    }
</style>
</head>
<body>
<div class="card">
<h1>⚠ Access Restricted</h1>
<p><%= message %></p>
</div>
</body>
</html>