     <section class="complaince-section">
<h2><i class="fa-solid fa-shield-halved text-primary"></i> Compliance Trainings</h2>
 
  <div class="grid" id="compliance-grid">
<% if (complianceTrainings.length === 0) { %>
<p><i class="fa-regular fa-face-frown text-muted"></i> No compliance trainings available.</p>
<% } else { %>
<% complianceTrainings.forEach(ct => {
        const statusClass = ct.status.toLowerCase().replace(/\s/g, '-');
        if (['completed', 'in-progress'].includes(statusClass)) { %>
 
          <a href="https://hexavarsity.csod.com/ui/lms-learning-details/app/curriculum/<%= ct.complianceId %>?isOnePlayer=true"
             target="_blank"
             class="card-link">
 
            <div class="card">
<h3>
<i class="fa-solid fa-book-open text-info"></i>
<%= ct.complianceName %>
</h3>
 
              <div class="ribbon <%= statusClass %>">
<% if(statusClass === 'completed') { %>
<i class="fa-solid fa-circle-check"></i>
<% } else { %>
<i class="fa-solid fa-spinner"></i>
<% } %>
<%= ct.status.toUpperCase() %>
</div>
</div>
 
          </a>
 
      <% } }); %>
<% } %>
</div>
</section>
  </div>

