  <%
  /* ---------- SAFE DATA HANDLING ---------- */
 
  const gradeNumber = userDetails.grade || "";
  const jobstreamText = userDetails.jobstream || "";
 

  const isTech = jobstreamText.toUpperCase().includes("TECH");
 
  const learningCategory =
    (gradeNumber >= 2 && gradeNumber <= 6 && isTech)
      ? "TECH"
      : "OTHERS";
 
  const safeProgress = typeof progressPercent !== "undefined"
    ? progressPercent
    : 0;
 
  const safeRating = typeof rating !== "undefined"
    ? rating
    : 0;
%>
 
<div id="ratingSummarySection">
    <div class="rating-3col">

  <!-- USER -->
  <div class="col-card">
    <div class="col-header">
      <i class="fa-solid fa-user" style="color: white;"></i>
      User Details
    </div>
    <div class="col-body" style="display:flex;flex-direction:column;justify-content:center;align-items:center">
      <div class="user-name" id="userName">
        <i class="fa-solid fa-user"></i>
        <span>
          <%= userDetails.firstName || '-' %> <%= userDetails.lastName || '' %>
        </span>
      </div>
      <div class="user-meta" id="userMeta">
        <i class="fa-solid fa-id-badge"></i>
        <span>
          <%= userDetails.softwareLevel || '-' %> | <%= userDetails.designation || '-' %>
        </span>
      </div>
      <div class="user-meta" id="userMeta">
        <i class="fa-solid fa-layer-group"></i>
        <span>
          Grade: G<%= gradeNumber || '-' %> | Job Stream: <%= jobstreamText || '-' %>
        </span>
      </div>
 
    </div>
  </div>

  <!-- RATING -->
  <div class="col-card">
    <div class="col-header">
      <i class="fa-solid fa-star"></i>
      Rating
    </div>
    <div class="col-body center">
      <div class="stars large" id="stars">
        <% for(let i = 1; i <= 5; i++) { %>
          <% if(i <= safeRating) { %>
            <span class="filled">★</span>
          <% } else { %>
            <span>★</span>
          <% } %>
        <% } %>
      </div>
      <div class="rating-number large" id="ratingNumber"><%= safeRating %> / 5</div>
      <div class="rating-label" id="ratingLabel">
        <% if(safeProgress >= 100) { %>
          Exceptional
        <% } else if(safeProgress >= 75) { %>
          Exceeds Expectation
        <% } else if(safeProgress >= 50) { %>
          Meets Expectation
        <% } else if(safeProgress >= 25) { %>
          Needs Improvement
        <% } else { %>
          Unsatisfactory
        <% } %>
      </div>
    </div>
  </div>

  <!-- PROGRESS -->
  <div class="col-card">
    <div class="col-header">
      <i class="fa-solid fa-chart-line" style="color: white;"></i>
      Learning Progress
    </div>

    <div class="col-body progress-col" style="justify-content: center;">
      <div class="progress-visual">
        <div class="circle-wrap small">
          <div class="circle" id="progressCircle" style="background: conic-gradient(#22c55e <%= safeProgress * 3.6 %>deg, #e5e7eb 0deg);">
            <div class="circle-inner">
              <div class="circle-percent" id="circlePercent"><%= safeProgress %>%</div>
              <div class="circle-label">Completed</div>
            </div>
          </div>
        </div>
      </div>
      <div style="display: flex;flex-direction: column;">
           <div class="user-meta" id="userMeta">
        <i class="fa-solid fa-graduation-cap"></i>
        <span>
          Learning Goal Category: <strong><%= learningCategory %></strong>
        </span>
      </div>
           <!-- <div class="hint-text" style="margin-top: 10px;">
          <i class="fa-solid fa-circle-info" style="color: gray !important;"></i>
          Complete goals sequentially to boost rating
        </div> -->
