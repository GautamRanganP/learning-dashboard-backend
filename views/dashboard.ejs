  <div id="tsr" class="tab-content" style="display:none;">
    <!-- TSR With External Certification section (Tech only) -->
     
<% if (userDetails.jobstream && userDetails.jobstream.toUpperCase() === "TECH") { %>
 <section class="training-section" style="margin-bottom: 20px;">
  <h2><i class="fa-solid fa-certificate text-danger"></i> TSR With External Certification</h2>

  <% if (!tsrWithExternalCertification || tsrWithExternalCertification.length === 0) { %>
    <p><i class="fa-regular fa-face-frown text-muted"></i> No certifications available.</p>
  <% } else { %>

    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">

      <% tsrWithExternalCertification.forEach(tsr => { %>
        <% if (tsr.certifications && tsr.certifications.length > 0) { %>
          <% tsr.certifications.forEach(cert => {
            const displayStatus = (cert.Status === "Registered" || cert.Status === "In Progress")
              ? "In Progress"
              : cert.Status;
            const statusClass = displayStatus.toLowerCase().replace(/\s/g, '-');
          %>

          <div class="card" style="padding: 0px;">
            
            <!-- TSR Title -->
            <h3 style="display: flex;
    align-items: center;
    justify-content: center;
    height: 50px;
    color: white;
    margin: 0px;
    background: rgb(7, 18, 94);">
              <i class="fa-solid fa-award"></i> <%= tsr.tsrTitle %>
            </h3>
             <% if (tsr.isBase) { %>
    <div style="
      background-color: #007bff; /* Bootstrap primary blue or customize */
      color: white;
      font-weight: bold;
      right: 0px;
      position: absolute;
      padding: 5px 12px;
      box-shadow: 0 0 8px rgba(0,123,255,0.6);
      font-size: 14px;
    ">
      Base TSR
    </div>
  <% } %>

            <!-- Certification Title -->
            <h3 style="padding-left: 22px;padding-top: 30px;min-height: 80px;">
              <i class="fa-solid fa-medal"></i> <%= cert.Title %>
            </h3>

            <!-- Complexity Level -->
            <div style="font-size: 0.9em; color: #666; margin-bottom: 8px;padding-left: 22px;">
              <% if (cert.Complexity === 'Advanced') { %>
                <!-- <i class="fa-solid fa-star text-danger" title="Advanced Level"></i> Advanced -->
                 Complexity Level : Advanced
              <% } else if (cert.Complexity === 'Basic') { %>
                <!-- <i class="fa-solid fa-circle text-info" title="Basic Level"></i> Basic -->
                 Complexity Level : Basic
              <% } else { %>
                Complexity Level : Unknown
              <% } %>
            </div>

            <div style="padding: 0px 22px;padding-bottom: 22px;">
            <!-- Status Ribbon -->
            <div class="ribbon <%= statusClass %>" style="font-weight: bold;">
              <% if (statusClass === 'completed') { %>
                <i class="fa-solid fa-circle-check"></i>
              <% } else { %>
                <i class="fa-solid fa-spinner"></i>
              <% } %>
              <%= cert.Status.toUpperCase() %>
            </div>
            </div>
          </div> <!-- card -->

          <% }) %>
        <% } else { %>
          <!-- If no certifications for this TSR, show full width message -->
          <!-- <div style="grid-column: 1 / -1; color: #888;">
            <p><i class="fa-regular fa-face-frown"></i> No certifications available for <%= tsr.tsrTitle %>.</p>
          </div> -->
        <% } %>
      <% }) %>
    </div>

  <% } %>
</section>
 <% } %>
  </div>

  <div id="ilt" class="tab-content" style="display:none;">
    <!-- ILT / VILT Sessions section -->
     
<section class="training-section">
  <div style="display: flex;justify-content: space-between;align-items: center;">
  <h2>ILT/VILT Sessions</h2>
  <p style="margin: 0;"><strong>Total Training Hours Completed:</strong> <%= totalHours.toFixed(2) %> hrs</p>
</div>
  <div class="session-list">
    <% 
      // Helper function to convert "HHHH:MM:SS" time string to decimal hours
      function timeToDecimalHours(timeStr) {
        if (!timeStr) return 0;
        const parts = timeStr.split(':');
        if (parts.length !== 3) return 0;
        const hours = parseInt(parts[0], 10);
        const minutes = parseInt(parts[1], 10);
        const seconds = parseInt(parts[2], 10);
        if (isNaN(hours) || isNaN(minutes) || isNaN(seconds)) return 0;
        return hours + (minutes / 60) + (seconds / 3600);
      }
    %>

    <% if (completedTrainings.length === 0) { %>
      <p>No completed session trainings found.</p>
    <% } else { %>
      <div class="grid" style="padding: 0;">
        <% completedTrainings.forEach(session => {
             const decimalHours = timeToDecimalHours(session.TrainingHours);
             const displayStatus = (session.Status === "Registered") ? "In Progress" : session.Status;
             const statusClass = displayStatus.toLowerCase().replace(/\s/g, '-');
        %>
          <div class="session-item card" style="position: relative;">
          <h3>
        <i class="fa-solid fa-laptop text-primary"></i>
        <%= session.Title %>
      </h3>
      <p>
        <i class="fa-solid fa-calendar-day text-success session-icon"></i>
        <strong class="session-text">Start Date</strong><span>:</span> <%= session.StartDateTime    %>
        <br>
        <i class="fa-solid fa-calendar-check text-danger session-icon"></i>
        <strong class="session-text">End Date</strong><span>:</span> <%= session.EndDateTime    %><br>
          <i class="fa-solid fa-hourglass-half text-warning session-icon"></i>
        <strong class="session-text">Duration</strong><span>:</span> <%= decimalHours %> hour<%= decimalHours !== 1 ? 's' : '' %> 
      </p>
      <div class="ribbon <%= statusClass %>">
        <i class="fa-solid fa-circle-check"></i> <%= session.Status.toUpperCase() %>
      </div>

          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
  </div> 
 
