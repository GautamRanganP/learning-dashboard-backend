<div id="learning-dashboard-grp">
<meta charset="UTF-8">
<title>Learning Dashboard</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="/css/style.css">

<div id="dashboardRoot" data-user='<%- JSON.stringify(userInfo) %>'>

<div class="container" >
  <div class="header-bar">
    <h1>
      <i class="fa-solid fa-graduation-cap"></i>
      Learning Dashboard - <span class="activeYearText">2026</span>
    </h1>
    <div class="policy-btn" id="openPolicy">
      <i class="fa-solid fa-circle-info"></i>
      Learning Goal Policy
    </div>
  </div>

  <div class="note">
    <i class="fa-solid fa-triangle-exclamation"></i>
    Note: Dashboard reflects learning goal completion only.
  </div>

 <div class="tabs" id="tabsSection">
    <div class="tab" data-year="2025">
      <i class="fa-solid fa-calendar-days"></i> 2025
    </div>
     <div class="tab active" data-year="2026">
      <i class="fa-solid fa-calendar-days"></i> 2026
    </div>
  </div>

<div id="main-content-lg-2025" style="display: none;">
    <hr style="border: none;
  height: 1.5px;
  background-color: lightgray;  /* light grey */
  margin: 24px 0;
  border-radius: 1px;">
    
  <!-- Error -->
 <div id="errorBox" style="
    font-size: 16px;
    min-height: 150px;
    line-height: 1.4;
    background-color: #fee2e2;
    color: #991b1b;
    padding: 20px 24px;
    border-radius: 8px;
    margin-bottom: 16px;
    font-weight: 600;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    box-shadow: 0 4px 8px rgba(153, 27, 27, 0.15);
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
    display: none;
    align-items: center;
    gap: 12px;
">
    <svg xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;" width="24" height="24" fill="none" stroke="#991b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-alert-circle">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12" y2="16"></line>
    </svg>
    <div id="errorMessage">
    </div>
</div>

  <!-- Learning Progress -->
  <div class="section" id="learningProgressSection">
    <div class="section-header">
      <i class="fa-solid fa-list-check"></i>
      Learning Goal Progress – <span class="activeYearText"></span>
    </div>
    <div class="goal-cards" id="goalCards"></div>
      <div class="legend-grp">
    <span class="completed"><i class="fa-solid fa-circle-check"></i> Completed</span>
    <span class="pending"><i class="fa-regular fa-clock"></i> Pending</span>
    <span class="waived"><i class="fa-solid fa-ban"></i> Waived</span>
  </div>
  </div>

  <!-- Rating Summary -->
  <div class="section" id="ratingSummarySection">
    <div class="section-header">
      <i class="fa-solid fa-star"></i>
      Learning Goals Rating Summary
    </div>
    <div class="rating-card">
      <div class="user-name">
        <i class="fa-solid fa-user"></i>
        <span id="userName"></span>
      </div>
      <div class="user-meta">
        <i class="fa-solid fa-id-badge"></i>
        <span id="userMeta"></span>
      </div>

      <div class="rating-row">
        <div class="stars" id="stars"></div>
        <div class="rating-number" id="ratingNumber"></div>
      </div>

      <div class="rating-label" id="ratingLabel"></div>

      <div class="progress-label">
        <i class="fa-solid fa-chart-line"></i>
        Learning Goal Progress
      </div>

      <div class="progress">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <div class="progress-percent" id="progressPercent"></div>
    </div>
  </div>
</div>


  
